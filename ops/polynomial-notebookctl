#!/usr/bin/env bash
set -Eeuo pipefail

PATH=/usr/sbin:/usr/bin:/sbin:/bin
DOCKER=/usr/bin/docker
IMAGE=polynomial-notebook:local
NETWORK=polynomial-notebook-internal
BASE=/opt/polynomial-notebook/users

die(){ echo "ERROR: $*" >&2; exit 1; }
is_integer(){ [[ "$1" =~ ^[0-9]+$ ]]; }
container_exists(){ "$DOCKER" container inspect "$NAME" >/dev/null 2>&1; }
container_running(){ [[ "$("$DOCKER" inspect --format '{{.State.Running}}' "$NAME" 2>/dev/null || true)" == "true" ]]; }
container_ip(){ "$DOCKER" inspect --format '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' "$NAME"; }

[[ "$EUID" -eq 0 ]] || die "必须由 root 运行"
[[ $# -ge 2 ]] || die "用法：polynomial-notebookctl ACTION USER_ID [参数]"

ACTION="$1"
USER_ID="$2"
[[ "$USER_ID" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]] || die "用户 ID 格式无效"

SHORT_ID="${USER_ID//-/}"
NAME="polynomial-notebook-${SHORT_ID}"
USER_ROOT="$BASE/$USER_ID"
WORK_DIR="$USER_ROOT/work"
DISK_IMAGE="$USER_ROOT/work.ext4"
TOKEN_FILE="$USER_ROOT/jupyter.token"

case "$ACTION" in
  start)
    [[ $# -eq 7 ]] || die "start 参数：USER_ID MEMORY_MB CPU_MILLI STORAGE_MB MAX_RUNNING QUOTA_ENABLED"
    MEMORY_MB="$3"; CPU_MILLI="$4"; STORAGE_MB="$5"; MAX_RUNNING="$6"; QUOTA_ENABLED="$7"
    is_integer "$MEMORY_MB" || die "内存参数无效"
    is_integer "$CPU_MILLI" || die "CPU 参数无效"
    is_integer "$STORAGE_MB" || die "存储参数无效"
    is_integer "$MAX_RUNNING" || die "并发参数无效"
    [[ "$QUOTA_ENABLED" == "0" || "$QUOTA_ENABLED" == "1" ]] || die "配额开关无效"
    (( MEMORY_MB >= 256 && MEMORY_MB <= 1024 )) || die "内存必须为 256–1024 MB"
    (( CPU_MILLI >= 250 && CPU_MILLI <= 2000 )) || die "CPU 必须为 250–2000 milli-CPU"
    (( STORAGE_MB >= 256 && STORAGE_MB <= 4096 )) || die "存储必须为 256–4096 MB"
    (( MAX_RUNNING >= 1 && MAX_RUNNING <= 3 )) || die "同时运行人数必须为 1–3"
    "$DOCKER" image inspect "$IMAGE" >/dev/null 2>&1 || die "找不到 Notebook 镜像"
    "$DOCKER" network inspect "$NETWORK" >/dev/null 2>&1 || die "找不到内部网络"

    if ! container_running; then
      RUNNING_COUNT="$("$DOCKER" ps --filter label=polynomial.notebook.managed=true --format '{{.ID}}' | /usr/bin/wc -l)"
      (( RUNNING_COUNT < MAX_RUNNING )) || die "当前 Python 使用人数已达到上限"
    fi

    /usr/bin/install -d -m 0711 -o root -g root "$USER_ROOT"
    /usr/bin/install -d -m 0700 -o 1000 -g 1000 "$WORK_DIR"
    if [[ ! -s "$TOKEN_FILE" ]]; then
      /usr/bin/openssl rand -hex 32 > "$TOKEN_FILE"
      /usr/bin/chown root:root "$TOKEN_FILE"
      /usr/bin/chmod 0600 "$TOKEN_FILE"
    fi
    TOKEN="$(<"$TOKEN_FILE")"
    if [[ "$QUOTA_ENABLED" == "1" || -f "$DISK_IMAGE" ]]; then
      NEED_RESIZE=0
      WANTED_BYTES=$(( STORAGE_MB * 1024 * 1024 ))
      if [[ ! -f "$DISK_IMAGE" ]]; then
        /usr/bin/truncate -s "$WANTED_BYTES" "$DISK_IMAGE"
        /usr/sbin/mkfs.ext4 -q -F -m 0 "$DISK_IMAGE"
        /usr/bin/chmod 0600 "$DISK_IMAGE"
      else
        CURRENT_BYTES="$(/usr/bin/stat -c '%s' "$DISK_IMAGE")"
        (( WANTED_BYTES >= CURRENT_BYTES )) || die "为防止数据损坏，现有存档盘不能直接缩小"
        if (( WANTED_BYTES > CURRENT_BYTES )); then /usr/bin/truncate -s "$WANTED_BYTES" "$DISK_IMAGE"; NEED_RESIZE=1; fi
      fi
      if ! /usr/bin/mountpoint -q "$WORK_DIR"; then /usr/bin/mount -o loop,nosuid,nodev "$DISK_IMAGE" "$WORK_DIR"; fi
      if (( NEED_RESIZE == 1 )); then
        LOOP_DEVICE="$(/usr/bin/findmnt -n -o SOURCE -T "$WORK_DIR")"
        /usr/sbin/losetup -c "$LOOP_DEVICE"
        /usr/sbin/resize2fs "$LOOP_DEVICE" >/dev/null
      fi
      /usr/bin/chown 1000:1000 "$WORK_DIR"
      /usr/bin/chmod 0700 "$WORK_DIR"
    fi

    CPUS="$(printf '%d.%03d' "$(( CPU_MILLI / 1000 ))" "$(( CPU_MILLI % 1000 ))")"
    if container_exists && [[ "$("$DOCKER" inspect --format '{{index .Config.Labels "polynomial.notebook.version"}}' "$NAME")" != "2" ]]; then
      container_running && "$DOCKER" stop --time 10 "$NAME" >/dev/null
      "$DOCKER" rm "$NAME" >/dev/null
    fi
    if container_exists; then
      "$DOCKER" update --memory "${MEMORY_MB}m" --memory-swap "${MEMORY_MB}m" --cpus "$CPUS" --pids-limit 128 "$NAME" >/dev/null
      container_running || "$DOCKER" start "$NAME" >/dev/null
    else
      "$DOCKER" run -d --name "$NAME" --hostname notebook --network "$NETWORK" --read-only \
        --tmpfs /tmp:rw,noexec,nosuid,size=128m,uid=1000,gid=1000,mode=1777 \
        --mount "type=bind,src=$WORK_DIR,dst=/home/notebook/work" \
        --env JUPYTER_RUNTIME_DIR=/tmp/jupyter-runtime --env JUPYTER_CONFIG_DIR=/tmp/jupyter-config \
        --env XDG_CONFIG_HOME=/tmp/xdg-config --env XDG_CACHE_HOME=/tmp/xdg-cache --env XDG_DATA_HOME=/tmp/xdg-data \
        --memory "${MEMORY_MB}m" --memory-swap "${MEMORY_MB}m" --cpus "$CPUS" --pids-limit 128 \
        --cap-drop ALL --security-opt no-new-privileges:true \
        --label polynomial.notebook.managed=true --label polynomial.notebook.version=2 --label "polynomial.notebook.user=$USER_ID" \
        "$IMAGE" jupyter-lab --ip=0.0.0.0 --port=8888 --no-browser --IdentityProvider.token="$TOKEN" \
        --ServerApp.base_url=/python/session/ --ServerApp.root_dir=/home/notebook/work \
        --ServerApp.allow_remote_access=True --ServerApp.terminals_enabled=False --LabApp.extension_manager=readonly >/dev/null
    fi
    sleep 2
    IP="$(container_ip)"
    [[ -n "$IP" ]] || die "容器没有获得内部地址"
    printf '{"running":true,"container":"%s","ip":"%s","token":"%s"}\n' "$NAME" "$IP" "$TOKEN"
    ;;
  status)
    [[ $# -eq 2 ]] || die "status 只需要 USER_ID"
    if ! container_exists; then echo '{"running":false}'; elif container_running; then TOKEN="$(<"$TOKEN_FILE")"; printf '{"running":true,"container":"%s","ip":"%s","token":"%s"}\n' "$NAME" "$(container_ip)" "$TOKEN"; else printf '{"running":false,"container":"%s"}\n' "$NAME"; fi
    ;;
  stop)
    [[ $# -eq 2 ]] || die "stop 只需要 USER_ID"
    if container_exists && container_running; then "$DOCKER" stop --time 10 "$NAME" >/dev/null; fi
    if /usr/bin/mountpoint -q "$WORK_DIR"; then /usr/bin/umount "$WORK_DIR"; fi
    echo '{"running":false}'
    ;;
  *) die "仅支持 start、status、stop" ;;
esac
